[Unit]
Description=LeafDepot Inventory Worker Service
After=network.target

[Service]
Type=simple
User=zihui-lang
Group=zihui-lang
WorkingDirectory=/home/zihui-lang/code/LeafDepot
Environment="PYTHONPATH=/home/zihui-lang/code/LeafDepot"
ExecStart=/home/zihui-lang/code/LeafDepot/log_wrapper.sh worker /home/zihui-lang/miniconda3/envs/tobacco_env/bin/python /home/zihui-lang/code/LeafDepot/services/worker/inventory_worker.py
Restart=always
RestartSec=10
